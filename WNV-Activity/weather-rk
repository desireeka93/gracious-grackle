##Do regression kriging with elevation
#read in raster as stars
dem<-read_stars("dbase/layers/dem.tif")
names(dem)<-"dem"
dem_full <- st_as_stars(dem)
dem_spatial <- as(dem_full, "Spatial")

for (i in 5:ncol(stations.tavg)) {
  #get only needed columns for reg krig (need to change 5 to i in for loop)
  stations.tavg.x<-na.omit(stations.tavg[,c(2:4,i)])

  #convert to spatial object
  tavg.sf <- st_as_sf(stations.tavg.x,
                      coords = c("lon", "lat"),
                      crs = 4326)

  #fit linear model
  fit1 <- lm(tavg.sf[[2]] ~ dem, data = tavg.sf)

  ##Add the residuals to the sf data object as a variable
  tavg.sf$resid <- residuals(fit1)

  ##Turn the residuals into a variogram
  resid.var <- variogram(resid ~ 1, data = tavg.sf, width = 0.5)

  resid.vgm <- vgm(psill = 8,
                   model = "Exp",
                   range = 1,
                   nugget = 0.5)

  ##Fit the model using the variogram and the model created by hand
  resid.vgm2 <- fit.variogram(resid.var, resid.vgm)


  ##Note:
  ## Note that as these are residuals, the mean is assumed known (=0), so we use simple kriging for the interpolation. The parameter beta is used to set the value of the mean.
  resid.sk = krige(resid ~ 1,
                   locations = tavg.sf,
                   newdata = dem_full,
                   model = resid.vgm2,
                   nmax = 20,
                   nmin = 8,
                   beta = 0)

  ##Store the linear model prediction in the DEM object
  dem$tavg.lm <- predict(fit1, dem)
  ##Add interpolated residuals to these values
  dem$tavg.rk <- dem$tavg.lm + resid.sk$var1.pred

  #save to database (have to paste actual yw name)
  write_stars(dem["tavg.rk"],paste0("dbase/weather/tavg",substr(colnames(tavg.sf[,2]), 3, 8)[1],".tif"),overwrite=TRUE)
}

