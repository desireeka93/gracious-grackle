for (i in 5:ncol(stations.prec)) {
  #get only needed columns for reg krig (need to change 5 to i in for loop)
  stations.prec.x<-na.omit(stations.prec[,c(2:4,i)])

  #convert to spatial object
  prec.sf <- st_as_sf(stations.prec.x,
                      coords = c("lon", "lat"),
                      crs = 4326)

  #fit linear model
  fit1 <- lm(prec.sf[[2]] ~ dem, data = prec.sf)

  ##Add the residuals to the sf data object as a variable
  prec.sf$resid <- residuals(fit1)

  ##Turn the residuals into a variogram
  resid.var <- variogram(resid ~ 1, data = prec.sf, width = 3)

  # Calculate variance of precipitation values
  precip_var <- var(prec.sf[[2]], na.rm = TRUE)

  # Adjust psill based on variance
  adaptive_psill <- max(0.5, min(3.0, precip_var * 0.1))

  resid.vgm <- vgm(psill = adaptive_psill,
                   model = "Exp",
                   range = 50,
                   nugget = 0.3)

  ##Fit the model using the variogram and the model created by hand
  resid.vgm2 <- fit.variogram(resid.var, resid.vgm)


  ##Note:
  ## Note that as these are residuals, the mean is assumed known (=0), so we use simple kriging for the interpolation. The parameter beta is used to set the value of the mean.
  resid.sk = krige(resid ~ 1,
                   locations = prec.sf,
                   newdata = dem_full,
                   model = resid.vgm2,
                   nmax = 30,
                   nmin = 12,
                   beta = 0)

  ##Store the linear model prediction in the DEM object
  dem$prec.lm <- predict(fit1, dem)
  ##Add interpolated residuals to these values
  dem$prec.rk <- dem$prec.lm + resid.sk$var1.pred

  #save to database
  if (all(is.na(dem$prec.rk[!is.na(dem$dem)]))) dem$prec.rk[!is.na(dem$dem)] <- 0
  dem["prec.rk"][dem["prec.rk"] > 300] <- 300
  dem["prec.rk"][dem["prec.rk"] < 0] <- 0
  write_stars(dem["prec.rk"],paste0("dbase/weather/prec",substr(colnames(prec.sf[,2]), 3, 8)[1],".tif"))
}

